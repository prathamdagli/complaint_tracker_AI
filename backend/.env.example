# ===== Copy this file to `.env` and fill in the real values. =====
# Never commit `.env` to git — it contains live secrets.

# ---------- Database ----------
# Local SQLite dev DB. Path is relative to the prisma/ folder.
DATABASE_URL="file:./dev.db"

# ---------- Services ----------
# Where the FastAPI ML engine listens (started by start.bat on port 8001)
ML_ENGINE_URL="http://localhost:8001"

# Where the Vite frontend serves (used for links in Telegram messages)
FRONTEND_URL="http://localhost:5173"

# ---------- Telegram Bot ----------
# Get one from @BotFather on Telegram:
#   1. /newbot  → pick a display name
#   2. choose a @username ending in `bot`
#   3. copy the token BotFather sends you
# Leave blank to disable the bot (the rest of the app works without it).
TELEGRAM_BOT_TOKEN=""

# ---------- Gemini / Gemma (AI reply drafter + chatbot) ----------
# Free API key from https://aistudio.google.com/apikey
# Leave blank to disable AI features (classification + retraining still work).
GEMINI_API_KEY=""
# Which Gemma / Gemini model to call. Defaults to gemma-3-27b-it (generous free tier).
# Alternatives worth trying: gemini-2.0-flash, gemini-2.5-flash
GEMINI_MODEL="gemma-3-27b-it"

# ---------- Authentication ----------
# JWT signing secret. Generate your own for production:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Has a hard-coded fallback for dev — override it in production.
# JWT_SECRET="replace_with_a_long_random_string"
